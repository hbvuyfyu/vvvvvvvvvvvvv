<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ── Top bar ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_camera_vc"
            android:layout_marginEnd="10dp"
            android:contentDescription="icon"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Virtual Cam"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"/>

        <!-- Root status pill -->
        <TextView
            android:id="@+id/tv_root_status"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="@string/checking"
            android:textColor="#00E5FF"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="@drawable/bg_btn_outline"/>

    </LinearLayout>

    <!-- Thin divider -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#111111"
        app:layout_constraintTop_toBottomOf="@id/top_bar"/>

    <!-- ── Scrollable body ───────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_body"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <!-- ── Media preview card ─────────────────────────────── -->
            <FrameLayout
                android:id="@+id/card_media"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/bg_card_dark"
                android:layout_marginBottom="20dp">

                <!-- Placeholder (shown when no media) -->
                <LinearLayout
                    android:id="@+id/layout_placeholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_camera_vc"
                        android:alpha="0.25"
                        android:contentDescription="placeholder"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No media selected"
                        android:textColor="#444444"
                        android:textSize="13sp"
                        android:layout_marginTop="10dp"/>
                </LinearLayout>

                <!-- Preview image (shown when media selected) -->
                <ImageView
                    android:id="@+id/iv_media_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="@string/media_preview"/>

                <!-- Media type badge -->
                <TextView
                    android:id="@+id/tv_media_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="10dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:textColor="#000000"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_btn_accent"
                    android:visibility="gone"/>

                <!-- Clear button -->
                <ImageView
                    android:id="@+id/btn_clear_media"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="top|start"
                    android:layout_margin="10dp"
                    android:src="@drawable/ic_close"
                    android:tint="#FFFFFF"
                    android:background="#66000000"
                    android:padding="4dp"
                    android:visibility="gone"
                    android:contentDescription="Clear"/>

            </FrameLayout>

            <!-- ── Pick buttons ───────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/btn_pick_image"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="@string/pick_image"
                    android:textColor="#00E5FF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_btn_outline"/>

                <TextView
                    android:id="@+id/btn_pick_video"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/pick_video"
                    android:textColor="#00E5FF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_btn_outline"/>

            </LinearLayout>

            <!-- ── Start / Stop button ────────────────────────────── -->
            <TextView
                android:id="@+id/btn_start_stop"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/start_vcam"
                android:textColor="#000000"
                android:textSize="17sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.04"
                android:alpha="0.4"
                android:background="@drawable/bg_btn_accent"
                android:layout_marginBottom="24dp"/>

            <!-- ── Status hint ─────────────────────────────────────── -->
            <TextView
                android:id="@+id/tv_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#444444"
                android:textSize="12sp"
                android:gravity="center"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
